# Root Project Gitignore (covers everything if initialized at root)

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules/

# Env files
.env
.env.*
!.env.example

# Build outputs
/server/dist/
/client/dist/

# Databases
*.sqlite
*.sqlite3
*.db
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal
database.sqlite*

# OS specific
.DS_Store
Thumbs.db

# IDEs
.idea/
.vscode/
*.swp
